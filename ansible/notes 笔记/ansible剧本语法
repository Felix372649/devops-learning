# # =================[ 8.fetch ]==================
# 从远程某主机获取文件到本地
# ansible host1 -m fetch -a 'src=/root/Luck.txt dest=1.txt'                 # fetch 从别的服务器里将文件 copy到本地服务器里！
#                                                                           # 他会创建一个服务器名字的目录，里面放着拷贝的文件/root/host1/1.txt

# # =================[ 9.cron ]==================
# minte时间=每隔10分钟去干活   job工作=调用系统sbin下的ntpdate 对192.168.233.130 这台机器进行时间对照！统一时间！
# ansible webserver -m cron -a 'name="beta" minute="*/10" job=/sbin/ntpdate 192.168.233.130 &> /dev/null'

# 语法：
# action : cron_backup=   #如果设置，则创建一个crontab备份[yes|no]
# cron_file=              #如果指定，使用这个文件 cron.d，而不是单个用户
# day=                    #日应该运行的工作(1-31,*,/2,)
# hour=                   #小时 (0-23,*,/2,)
# minute=                 #分钟(0-59,*,/2,)
# month=                  #月(1-12,*,/2,)
# weekday=                #周 (0-6 for Sunday-Saturday,*)
# job=                    #指明运行的命令是什么
# name=                   #定时任务描述
# reboot                  #任务在重启时运行，不建议使用，建议使用special_time


# # =================[ 10.group ]==================
#       group用户组模块，添加或删除组
# 参数：
# gid               # 设置组的GID号
# name=             # 管理组的名称
# state             # 指定组状态，默认为创建，设置值为absent为删除
# system            # 设置值为yes，表示创建系统组
# # ------------------------------------------------
# ansible webserver -m group -a 'name=Luck gid=1010 state=present'           # 在主机上，确保存在一个名字叫 Luck 的用户组,没有就新建，有了就不动!


# # =================[ 11.script ]==================
# 指定节点运行服务端的脚本，在节点机器上运行！
# 核心参数：
# script（必须）    # 指定你本地脚本的路径（例如 ./update.sh）。
# creates（推荐）   # 远程主机上的一个文件。如果该文件已存在，则跳过执行脚本。这是实现幂等性的关键。
# removes           # 远程主机上的一个文件。如果该文件存在，则执行脚本（与 creates 相反）。
# chdir             # 在远程主机上执行脚本前，先切换到这个目录。
# args              # 把参数传给脚本（例如 script: /tmp/test.sh args='--force'）。

# ansible webserver -m script -a "./root/install_nginx.sh"


# # =================[ 12.unarchive ]==================
