# 部署完ansible后
# 免密码ssh-key  加  sshpass检测安装
ssh-key-aaa(){

if ! rpm -q sshpass &> /dev/null; then
    if ! yum install -y sshpass; then
        echo "======[警告]======"
        echo "安装sshpass失败！ "
        echo "=================="
        return 6
    fi
fi

if ! ls -l ~/.ssh/id_* &> /dev/null; then
    if ! ssh-keygen -t rsa -f ~/.ssh/id_rsa -N "" -q 1> /dev/null; then
        #-t rsa：指定生成 RSA 类型的密钥。
        #-f ~/.ssh/id_rsa：直接指定生成的密钥文件存放路径（跳过“确认保存路径”的回车）。
        #-N ""：直接将密钥的密码设置为空字符串（跳过“输入密码”和“确认密码”的两次回车）。
        #-q：静默模式（Quiet），不在终端输出生成的图案和提示信息，让脚本执行更干净。
        echo "警告：密钥生成失败！"
        return 7
    fi
fi

local server_hosts_ip=(
    "192.168.233.130"
    "192.168.233.131"
    "192.168.233.132"
    "192.168.233.133"
)

local a=7

for i in "${server_hosts_ip[@]}"
do
let a++
    if ! sshpass -p '666666' ssh-copy-id -o StrictHostKeyChecking=no -i ~/.ssh/id_rsa.pub root@"${i}" 1> /dev/null; then
        #sshpass -p '密码'：在非交互模式下帮程序自动填入密码。
        #-i ~/.ssh/id_rsa.pub：明确指定要拷贝的公钥文件路径。
        echo "警告：推送 $i 公钥失败！"
        return "$a"
    fi
done

}


#定义主机清单
ipbbb(){

local server_hosts_ip=(
    "ansible"
    "host1"
    "host2"
    "host3"
    "host4"
)


cat <<EOM
============[定义主机清单]============

  检测主机上/etc/ansible/hosts配置...

======================================
EOM


for i in "${server_hosts_ip[@]}"
do
    # grep -x：整行精确匹配
    # grep -q：静默模式，只返回状态码，不输出任何内容，专门用于条件判断
if ! grep -xq "$i" /etc/ansible/hosts &> /dev/null; then
        echo "已将ip： ${i}  写入/etc/ansible/hosts文本中"
        echo "$i" >> /etc/ansible/hosts
    fi
done

export ANSIBLE_HOST_KEY_CHECKING=False
for a in "${server_hosts_ip[@]}"
do
    if ! ansible "$a" -m ping -o -u root -k; then
        #-k交互式密码 -u账号 -o显示信息内容排成一排
        echo "警告： $a 连通性测试失败！"
    fi
done




}




#=====================================================================
#      安装ansible

ipaaa # 第一步：首先在主机上检测hosts配置

echo "检测当前网络环境..."
if ping -c 2 www.baidu.com &> /dev/null; then
    yum_ali # 第二步：检测配置yum源

    echo "安装 epel-release 中，请稍后..."
    yum install -y epel-release &> /dev/null
        if [[ $? -ne 0 ]]; then
            echo "epel-release失败"
            return 1
        fi

    echo "安装 ansible 中，请稍后..."
    yum install -y ansible &> /dev/null
        if [[ $? -eq 0 ]]; then
            echo "======[系统提示】======"
            echo "|   ansible安装成功   |"
            echo "======================="

        else
            echo "ansible下载失败！"
            return 2
        fi

else
    echo "无网络执行本地安装包！"
    server_goujia
fi

ssh-key-aaa
ipbbb
