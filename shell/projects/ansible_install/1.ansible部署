#!/bin/bash
#ansible部署
#无网络安装查看构架
server_goujia(){
local goujia=$(uname -m)
    if [[ $goujia == "x86_64" ]]; then
        echo "本服务器构架为： x86_64"
        else
        echo "目前没有离线安装包！"
    fi
}


# 第一步：在主机上配置hosts，4个客户机不用配置！
ipaaa(){
local server_hosts_ip=(
    "192.168.233.128 ansible"
    "192.168.233.130 host1"
    "192.168.233.131 host2"
    "192.168.233.132 host3"
    "192.168.233.133 host4"
)
cat <<EOM
============[系统]============

检测是否写入/etc/hosts配置...

==============================
EOM

for i in "${server_hosts_ip[@]}"
do

        # grep -x：整行精确匹配
        # grep -q：静默模式，只返回状态码，不输出任何内容，专门用于条件判断
grep -xq "$i" /etc/hosts
        if [[ $? -ne 0 ]]; then
                echo "已将ip： ${i}  写入/etc/hosts文本中"
                echo "${i}" >> /etc/hosts
        fi
done
}



# 第二步:检测配置yum源
yum_ali(){
yum makecache -y &> /dev/null
    if [[ $? -ne 0 ]]; then
        rm  -rf /etc/yum.repos.d/*

        echo "阿里云 CentOS-7 base 基础源下载中，请稍后..."
        curl -o /etc/yum.repos.d/CentOS-Base.repo https://mirrors.aliyun.com/repo/Centos-7.repo &> /dev/null
            if [[ $? -ne 0 ]]; then
                echo "阿里云 CentOS-7 base 基础源下载失败！"
                return 3
            fi

        echo "阿里云 epel 扩展源下载中，请稍后..."
        curl -o /etc/yum.repos.d/epel.repo https://mirrors.aliyun.com/repo/epel-7.repo &> /dev/null
            if [[ $? -ne 0 ]]; then
                echo "阿里云 epel 扩展源下载失败！"
                return 4
            fi

        yum clean all &> /dev/null
        yum makecache &> /dev/null
            if [[ $? -ne 0 ]]; then
                echo "新源缓存生成失败，请检查源配置或网络"
                return 5
            fi
    fi
}


