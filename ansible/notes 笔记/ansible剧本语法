# #=================[1.shell模块]==================
# ansible webserver -m shell -a 'hostname' -o                 # 查看主机名 -o   ：One-line单行输出。会把结果压缩成一行显示，看起来更清爽，适合人眼阅读。
# ansible webserver -m shell -a 'hostname' -o -f 2            # 查看主机名 只显示两列 -f 代表 Forks并发数 -f 2 表示 Ansible 会同时向 2 台主机发送命令。
# ansible webserver -m shell -a 'yum -y install httpd' -o     # 安装apache
# ansible host3 -m shell -a 'uptime' -o                       # uptime（查看系统负载）命令，结果单行输出


# #=================[2.复制模块]==================
