#======【 列 表 list - 切 片】======
#----------------------------------------

# 切片时指对操作的数据截取其中一部分的操作。列表、字符串、元组都支持切片操作。
# s = ["A", "C", "E", "B", "D", "E", "G"]
# 语法: 序列数据[开始索引:结束索引:步长]
# 不包含结束索引位置对应的元素(开始索引未指定默认为0; 结束索引未指定默认为-1; 步长未指定默认为1)
# 索引采用正向、反向索引都可以
# 步长时选取间隔，默认步长为1

#        开始索引(默认0)    结束索引   步长(默认1)
# print(type(s[   0     :    5     :    1    ]))

# print(s[:5:1])  # 简化写法1 意思一样！
# print(s[:5:])   # 简化写法2 意思一样！
# print(s[:5])    # 简化写法3 意思一样！
# print(s[0:5:2]) # 步长为2 中间跳过一个元素,C和B就被跳过不显示了!
# print(s[0:5:3]) # 步长为3 中间跳过两个元素,CE和D就被跳过了！
# print(s[1:7:3]) # 从索引1开始 索引7结束，步长为3，中间跳过两个元素,EB和EG就被跳过了！
# print(s[0:-2:1])
# print(s[0:5:1])

# Python的切片语法中，有一个非常核心且强制的规则：“顾头不顾尾”。
# 也就是说，切片操作会包含起始位置的元素，但绝对不包含结束位置的元素。


