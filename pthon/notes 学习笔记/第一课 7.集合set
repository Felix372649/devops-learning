# 集合 (set) 的特点？
#       无序、不可重复、可修改（不要依赖显示顺序）

# 集合 (set) 的定义及常用操作
#       定义 1: 集合名 = {元素1,元素2,元素3...}
#       定义 2: 集合名 = set()

# 常用操作:
#       添加: s1.add(..)
#       删除: s1.remove(..) / s1.pop() / s1.clear()
#       交、并、差集: s1.intersection(s2) / s1.union(s2) / s1.difference(s2)

#=====================[ 实 例 ]=======================
# 根据提供的班级学生的选课情况，完成如下需求：
# 1.找出同时选修了法语和艺术的学生
# 2.找出同时选修了所有四门课程的学生
# 3.找出选修了足球，但是没有选修篮球的学生
# 4.统计每一个学生选修的课程数量

# 选修足球学生名单
football_set = {"王林", "曾牛", "徐立国", "遁天", "天运子", "韩立", "厉飞雨", "乌丑", "紫灵"}

# 选修篮球学生名单
basketball_set = {"张铁", "墨居仁", "王林", "姜老道", "曾牛", "王蝉", "韩立", "天运子", "李化元", "厉飞雨", "云露"}

# 选修法语学生名单
french_set = {"许木", "王卓", "十三", "虎咆", "姜老道", "天运子", "红蝶", "厉飞雨", "韩立", "曾牛"}

# 选修艺术学生名单
art_set = {"遁天", "天运子", "韩立", "虎咆", "姜老道", "紫灵"}


# 1、同时选修了法语和艺术的学生:
#------[方式1]------
fa_set=french_set.intersection(art_set)
print(fa_set)

#------[方式2]------
fa_set2=french_set & art_set # & 交集
print(fa_set2)


# 2、同时选修了所有四门课程的学生
fa_set3=football_set & basketball_set & french_set & art_set # & 交集
print(fa_set3)


# 3、选修了足球，但是没有选修篮球的学生
#------[方式1]------
fa_set4=football_set.difference(basketball_set)
print(fa_set4)

#------[方式2]------
fa_set4=football_set - basketball_set   # - 差集
print(fa_set4)

#------[方式3]------
# 集合推导式--〉快速构建集合，语法：{要往集合中添加的数据 for s in set1 if 条件]
fa_set4={s for s in football_set if s not in basketball_set}
# 循环每轮 将 football_set输入到s中，每输入一个元素到s里，就去 basketball_set里 验证 s的元素 是否不存在basketball_set当中！
# 如不存在就写入fa_set4里！
print(fa_set4)


# 4、每一个学生选修的课程数量
fa_set5 = football_set.union(basketball_set).union(french_set).union(art_set)
print(fa_set5)
fa_set6 = football_set | basketball_set | french_set | art_set       # 并集 |
print(fa_set6)

all_list = [*football_set, *basketball_set, *french_set, *art_set,]  # 这个 *（星号）叫做解包运算符! 把这四个包里的东西全都倒进all_list列表里
for i in fa_set6:                                                    # all_list里有所有重复的名单！   # fa_set6里有所有名单不重复！
    print(f"学生:{i}\t选修了：{all_list.count(i)}节课")                # 在不重复的名单里 每轮拿一个名字，在一堆重复的名单里进行统计 重复了几次！
                                                                     # 所以all_list.count(i) 每一轮统计一位学生名字！看看重复了几次！就是报了几科！


