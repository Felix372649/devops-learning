#   第十步：
ansible_playbook(){
ansible-playbook apache.yaml --syntax-check  # 检验语法 --syntax-check
ansible-playbook apache.yaml --list-tasks    # 列出任务 --list-tasks
ansible-playbook apache.yaml --list-hosts    # 列出主机 --list-hosts

ansible-playbook apache.yaml                 # 用ansible执行剧本！
#这块需要记playbook 用谁执行？ansible！剧本在哪里？叫啥名？apache.yaml 得记住以yaml结尾的文件！简称压马路文件！
}



#======【主程序执行顺序】======
all_remove          # 第一步 清理目标主机
install_yum_httpd   # 第二步 在ansible主机服务器上安装httpd
mkdir_apache        # 第三步 创建目录
cd_apache           # 第四步 进图目录里
httpd_conf          # 第五步 看看有没有这httpd.conf文件
grep_listen_80      # 第六步 查Listen 80
cp_httpd_conf       # 第七步 将/etc/httpd/conf/httpd.conf复制到/root/apache里
sed_listen_80       # 第八步 Listen 80 改为：Listen 8080
vim_apache          # 第九步 编写剧本任务
ansible_playbook    # 第十步 执行剧本！
